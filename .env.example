# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- System / Timezone ---
# Optional — timezone for container logs and scheduled sync tasks (defaults to Asia/Jerusalem if unset).
# TZ=Asia/Jerusalem

# --- Postgres / pgvector ---
POSTGRES_USER=self_docs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=self_docs

# --- Traefik ---
# Hostname the mcp-server is routed from (e.g. docs-mcp.lan.example.com)
DOCS_MCP_HOSTNAME=docs-mcp.example.lan
# Name of the pre-existing external Traefik docker network to join
TRAEFIK_NETWORK=traefik_proxy
# Traefik entrypoint the mcp-server router attaches to. Home-lab convention is
# a TLS-terminated `websecure`; set to `web` (or your own name) if this LAN's
# Traefik has no TLS resolver configured for this router.
TRAEFIK_ENTRYPOINT=websecure

# --- Ingestion auth ---
# Required — the ingestion service refuses to start without this and
# /sync requires `Authorization: Bearer $SYNC_TOKEN`.
SYNC_TOKEN=change-me

# --- MCP server auth ---
# Required — the mcp-server refuses tool calls without this and requests
# must send `Authorization: Bearer $MCP_TOKEN`.
MCP_TOKEN=change-me
